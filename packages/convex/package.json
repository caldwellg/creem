{
  "name": "@creem_io/convex",
  "description": "A Creem component for Convex.",
  "author": "Micha Mailaender",
  "repository": {
    "type": "git",
    "url": "https://github.com/armitage-labs/creem.git",
    "directory": "packages/convex"
  },
  "homepage": "https://github.com/armitage-labs/creem/tree/main/packages/convex",
  "bugs": {
    "url": "https://github.com/armitage-labs/creem/issues"
  },
  "version": "0.3.2",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "convex",
    "component",
    "creem",
    "stripe",
    "subscription",
    "billing",
    "payments",
    "checkout"
  ],
  "type": "module",
  "sideEffects": [
    "./src/client/polyfill.ts",
    "./dist/client/polyfill.js"
  ],
  "scripts": {
    "dev:react": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta' --names 'frontend,backend,build' 'pnpm dev:frontend:react' 'pnpm dev:backend' 'pnpm dev:build'",
    "dev:svelte": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta' --names 'frontend,backend,build' 'pnpm dev:frontend:svelte' 'pnpm dev:backend' 'pnpm dev:build'",
    "dev:backend": "convex dev --typecheck-components",
    "dev:frontend:react": "vite --clearScreen false --config example-react/vite.config.ts",
    "dev:frontend:svelte": "vite --clearScreen false --config example-svelte/vite.config.ts",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.svelte' -i '**/*.test.ts' -i '**/*.test.tsx' -i 'src/core/**/*.d.ts' -c 'npx convex codegen --component-dir ./src/component && pnpm build' --initial",
    "predev": "convex dev --skip-push",
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsc --project ./tsconfig.build.json && svelte-package --input src/svelte --output dist/svelte --tsconfig ./tsconfig.svelte-package.json && node ./scripts/clean-svelte-package-artifacts.mjs",
    "typecheck": "tsc --noEmit -p ./tsconfig.json && tsc --noEmit -p ./convex/tsconfig.json && tsc --noEmit -p ./example-react/tsconfig.json && tsc --noEmit -p ./example-svelte/tsconfig.json && svelte-check --tsconfig ./tsconfig.svelte-package.json && svelte-check --tsconfig ./example-svelte/tsconfig.json",
    "check": "pnpm lint && pnpm typecheck",
    "format": "prettier --write .",
    "pack:package": "pnpm build && pnpm pack --pack-destination /tmp/convex-creem-pack",
    "lint": "eslint .",
    "all": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta,cyan' --names 'frontend,backend,build,test' 'pnpm dev:frontend:react' 'pnpm dev:backend' 'pnpm dev:build' 'pnpm test:watch'",
    "test": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --typecheck",
    "test:watch": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest --typecheck --clearScreen false",
    "test:debug": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --coverage --coverage.reporter=text",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./styles": "./src/library.css",
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.31.0",
    "@ark-ui/svelte": "^5.16.0",
    "convex": "^1.29.0",
    "convex-svelte": ">=0.14.0",
    "creem": "^1.5.3",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "@ark-ui/react": {
      "optional": true
    },
    "@ark-ui/svelte": {
      "optional": true
    },
    "convex-svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@ark-ui/react": "^5.36.2",
    "@ark-ui/svelte": "^5.22.1",
    "@convex-dev/eslint-plugin": "2.0.0",
    "@edge-runtime/vm": "5.0.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-table": "8.21.3",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.0",
    "chokidar-cli": "3.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "^10.0.3",
    "convex": "^1.41.0",
    "convex-helpers": "0.1.119",
    "convex-svelte": "^0.14.0",
    "convex-test": "0.0.53",
    "cpy-cli": "7.0.0",
    "creem": "^1.5.3",
    "eslint": "10.5.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "0.577.0",
    "next-themes": "0.4.6",
    "path-exists-cli": "2.0.0",
    "pkg-pr-new": "0.0.75",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remeda": "2.39.0",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "use-debounce": "10.1.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "buffer": "^6.0.3",
    "convex-helpers": "^0.1.119",
    "marked": "^18.0.5",
    "remeda": "^2.39.0"
  }
}
